#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")
basedir_win="$basedir"
exe=""
msys=""

case `uname -a` in
  *CYGWIN*|*MINGW*|*MSYS*)
    if command -v cygpath > /dev/null 2>&1; then
      basedir_win=`cygpath -w "$basedir"`
    fi
    exe=".exe"
    msys="true"
  ;;
  *WSL2*)
    if command -v wslpath > /dev/null 2>&1; then
      basedir_win="$(wslpath -w "$basedir" 2> /dev/null)"
      if [ $? -ne 0 ] || [ -z "$basedir_win" ]; then
        basedir_win="$basedir"
      else
        exe=".exe"
      fi
    fi
  ;;
esac

if [ -n "$exe" ] && [ -x "$basedir/node.exe" ]; then
  exec "$basedir/node.exe"  "$basedir_win/../node_modules/pnpm/bin/pnpx.mjs" "$@"
elif [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../node_modules/pnpm/bin/pnpx.mjs" "$@"
elif command -v node >/dev/null 2>&1; then
  exec node  "$basedir/../node_modules/pnpm/bin/pnpx.mjs" "$@"
elif [ -n "$exe" ] && command -v node.exe >/dev/null 2>&1; then
  exec node.exe  "$basedir_win/../node_modules/pnpm/bin/pnpx.mjs" "$@"
else
  exec node  "$basedir/../node_modules/pnpm/bin/pnpx.mjs" "$@"
fi
# cmd-shim-target=/mnt/desktop/compro/.pnpm-store/v11/links/@/pnpm/11.13.1/561b0a3f4e744d7379205aad657578bee95b5addf3cf10495c397e22f47682fa/node_modules/pnpm/bin/pnpx.mjs
