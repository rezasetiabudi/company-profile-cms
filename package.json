{
  "name": "compro-template",
  "version": "1.0.0",
  "description": "Generic Company Profile Starter Template — Payload CMS + Next.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "node --import tsx src/seed.ts",
    "seed:generic": "PRESET=generic node --import tsx src/seed.ts",
    "seed:hospital": "PRESET=hospital node --import tsx src/seed.ts",
    "seed:construction": "PRESET=construction node --import tsx src/seed.ts",
    "seed:list": "PRESET=list node --import tsx src/seed.ts",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap",
    "db:reset": "docker exec compro-db psql -U postgres -c \"DROP DATABASE IF EXISTS compro WITH (FORCE);\" && docker exec compro-db psql -U postgres -c \"CREATE DATABASE compro;\"",
    "reseed": "pnpm db:reset && pnpm seed",
    "reseed:generic": "pnpm db:reset && pnpm seed:generic",
    "reseed:hospital": "pnpm db:reset && pnpm seed:hospital",
    "reseed:construction": "pnpm db:reset && pnpm seed:construction"
  },
  "type": "module",
  "dependencies": {
    "@payloadcms/db-postgres": "^3.86.0",
    "@payloadcms/next": "^3.86.0",
    "@payloadcms/richtext-lexical": "^3.86.0",
    "@tailwindcss/postcss": "^4.3.2",
    "dotenv": "^17.4.2",
    "next": "^16.2.10",
    "payload": "^3.86.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.10.0"
}
