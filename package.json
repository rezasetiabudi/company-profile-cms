{
  "name": "compro-template",
  "version": "1.0.0",
  "description": "Generic Company Profile Starter Template — Payload CMS + Next.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "tsx src/seed.ts",
    "seed:generic": "cross-env PRESET=generic tsx src/seed.ts",
    "seed:hospital": "cross-env PRESET=hospital tsx src/seed.ts",
    "seed:construction": "cross-env PRESET=construction tsx src/seed.ts",
    "seed:list": "cross-env PRESET=list tsx src/seed.ts",
    "generate:types": "payload generate:types",
    "generate:importmap": "payload generate:importmap"
  },
  "type": "module",
  "dependencies": {
    "@payloadcms/db-postgres": "^3.86.0",
    "@payloadcms/next": "^3.86.0",
    "@payloadcms/richtext-lexical": "^3.86.0",
    "@tailwindcss/postcss": "^4.3.2",
    "dotenv": "^17.4.2",
    "next": "^16.2.10",
    "payload": "^3.86.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.35.3",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@11.13.1"
}
